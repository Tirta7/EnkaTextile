{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --env-file=../../.env src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "start:prod": "cross-env NODE_ENV=production node --env-file=../../.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ioredis": "^5.11.1",
    "node-cron": "^4.5.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/busboy": "^1.5.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
